{
  "description": "Audible second-brain — surface freshness + calibration prompts at SessionStart",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/check-freshness.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
